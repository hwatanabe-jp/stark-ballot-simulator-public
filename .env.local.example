# STARK Ballot Simulator local env template
# Copy with: cp .env.local.example .env.local

# =============================================================================
# Core App Runtime
# =============================================================================
NODE_ENV=development
ENV_NAME=development
# Keep this explicit non-production marker when using local Turnstile bypass.
# `ENV_NAME=development` alone is not used by the fail-closed runtime classifier.
RUNTIME_DEPLOYMENT_ENV=develop
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Client-side mock fetches. Set to false to exercise the real app handlers.
NEXT_PUBLIC_USE_MOCK_API=true

# =============================================================================
# API / HTTP
# =============================================================================
# Unset to use the same-origin Next.js /api routes.
# NEXT_PUBLIC_API_BASE_URL=https://<api-id>.execute-api.ap-northeast-1.amazonaws.com
HONO_CORS_ALLOW_ORIGINS=http://localhost:3000

# Set both together to apply API Gateway stage throttling.
# API_THROTTLE_RATE_LIMIT=25
# API_THROTTLE_BURST_LIMIT=50

# Optional custom domain for a deployed API Gateway.
# API_DOMAIN_NAME=api.example.com
# API_DOMAIN_CERT_ARN=arn:aws:acm:ap-northeast-1:<account-id>:certificate/<id>
# DISABLE_EXECUTE_API_ENDPOINT=true

# Max request body size in bytes for API routes (default: 16384).
# API_REQUEST_BODY_LIMIT_BYTES=16384

# Extra connect-src entries (space or comma separated).
# CSP_CONNECT_SRC_EXTRA=https://api.example.com wss://realtime.example.com

# =============================================================================
# Turnstile / Session Security
# =============================================================================
# Development dummy keys. Replace with real keys before using real Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_ALLOWED_HOSTNAMES=localhost

# Local bypass. Keep both 0 in production.
NEXT_PUBLIC_TURNSTILE_BYPASS=1
TURNSTILE_BYPASS=1

# Require Turnstile on POST /api/session too.
NEXT_PUBLIC_SESSION_CREATE_TURNSTILE_REQUIRED=0
SESSION_CREATE_TURNSTILE_REQUIRED=0

# Trusted proxy headers: none | api-gateway | cloudflare | both
TRUSTED_PROXY=none

# Required outside tests. Must be 32+ chars and not a placeholder.
SESSION_CAPABILITY_SECRET=change-me-please-min-32-chars-and-rotate
SESSION_CAPABILITY_TTL_SECONDS=86400

# Optional request-scoped debug logging token HMAC secret.
# DEBUG_LOG_SECRET=replace-with-random-32-plus-chars
# DEBUG_LOG_MAX_TTL_SECONDS=900
# DEBUG_LOG_COOKIE_SECURE=0

# =============================================================================
# Session Store / Amplify Data
# =============================================================================
USE_MOCK_STORE=true
USE_AMPLIFY_DATA=false
MAX_SESSIONS=100

# File-backed mock store options. Useful for production-mode local tests.
# PERSIST_MOCK_STORE=1
# FILE_MOCK_STORE_DIR=.tmp/mock-sessions
FILE_STORE_CACHE_LIMIT=32
# DISABLE_FILE_STORE_CACHE=1

# Required when USE_MOCK_STORE=false.
AMPLIFY_DATA_REGION=ap-northeast-1
# AMPLIFY_DATA_ENDPOINT=https://<api-id>.appsync-api.ap-northeast-1.amazonaws.com/graphql
# AMPLIFY_DATA_API_ID=<api-id>
# AWS_REGION=ap-northeast-1
# AWS_SDK_LOAD_CONFIG=1
# COGNITO_IDENTITY_POOL_ID=ap-northeast-1:<identity-pool-id>
# VOTE_SECRET_ENCRYPTION_KEY=<64-hex-or-base64>
AMPLIFY_DATA_TTL_SECONDS=1800
AMPLIFY_DATA_VERIFICATION_TTL_SECONDS=86400

# =============================================================================
# zkVM / Verifier
# =============================================================================
USE_MOCK_ZKVM=true
RISC0_DEV_MODE=1
ZKVM_BINARY_PATH=./zkvm/target/release/host

# Leave EXPECTED_IMAGE_ID unset to use public/imageId-mapping.json.
# EXPECTED_IMAGE_ID=0x<64-hex-chars>
EXPECTED_IMAGE_ID_VARIANT=default

VERIFIER_SERVICE_BIN=./verifier-service/target/release/verifier-service
VERIFIER_WORK_DIR=/tmp/verifier-work

# Only for deployed verifier-service-runner / public download flows.
# VERIFIER_SERVICE_RUNNER_FUNCTION_NAME=amplify-<app-id>-<env>-verifierservicerunnerlam-<suffix>
# VERIFIER_SERVICE_RUNNER_ARN=arn:aws:lambda:ap-northeast-1:<account-id>:function:<name>
# VERIFIER_PUBLIC_BASE_URL=http://localhost:3000

# Test-only or controlled local overrides.
# FORCE_DEV_MODE=true
# ALLOW_INSECURE_ZKVM=true
# ALLOW_DEV_MODE_VERIFICATION=true

# =============================================================================
# Verification Evidence
# =============================================================================
NEXT_PUBLIC_STH_SOURCES=/api/sth
NEXT_PUBLIC_STH_MIN_MATCHES=1

# Timestamp authority endpoints used by deployment helpers.
# TSA_URL=https://freetsa.org/tsr
# TSA_CERT_URL=https://freetsa.org/files/cacert.pem

# =============================================================================
# Async Finalize / Bundle Delivery
# =============================================================================
FINALIZE_ASYNC_MODE=false
PROVER_PUBLISH_MAX_ATTEMPTS=3
PROVER_STEP_FUNCTIONS_ENABLED=false
PROVER_LAMBDA_CONCURRENCY=2

# Required only when you call /api/finalize/callback directly.
# FINALIZE_CALLBACK_SECRET=replace-with-random-32-plus-chars
FINALIZE_CALLBACK_MAX_SKEW_MS=300000
FINALIZE_CALLBACK_BODY_LIMIT_BYTES=8192

# PROVER_WORK_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/<account-id>/<queue-name>
# PROVER_WORK_QUEUE_ARN=arn:aws:sqs:ap-northeast-1:<account-id>:<queue-name>
# PROVER_STATE_MACHINE_ARN=arn:aws:states:ap-northeast-1:<account-id>:stateMachine:<name>

USE_S3=false
# S3_PROOF_BUCKET=<bucket-name>
S3_PROOF_PREFIX=sessions/
# S3_SIGNED_URL_TTL_SECONDS=3600
# S3_BUNDLE_SIGNED_URL_TTL_SECONDS=300

# =============================================================================
# Rate Limits
# =============================================================================
RATE_LIMIT_STORE=memory
SESSION_CREATE_RATE_LIMIT=30
SESSION_CREATE_RATE_LIMIT_WINDOW_MS=60000
SESSION_CREATE_RATE_LIMIT_MAX_BUCKETS=10000
VOTE_RATE_LIMIT=10
VOTE_RATE_LIMIT_WINDOW_MS=60000
VOTE_RATE_LIMIT_MAX_BUCKETS=10000
FINALIZE_CANCEL_RATE_LIMIT=5
FINALIZE_CANCEL_RATE_LIMIT_WINDOW_MS=60000
FINALIZE_CANCEL_RATE_LIMIT_MAX_BUCKETS=10000
ZKVM_RATE_LIMIT_PER_IP=50
ZKVM_RATE_LIMIT_WINDOW_MS=86400000
ZKVM_GLOBAL_DAILY_LIMIT=1000
ZKVM_GLOBAL_HOURLY_LIMIT=100
NEXT_PUBLIC_ZKVM_RATE_LIMIT_PER_IP=50

# Dynamo-backed rate limiting.
# RATE_LIMIT_EVENTS_TABLE=stark-ballot-simulator-rate-limit-events
# RATE_LIMIT_COUNTERS_TABLE=stark-ballot-simulator-rate-limit-counters
# DYNAMODB_ENDPOINT=http://localhost:8000

# Allow fallback IP 0.0.0.0 when client IP headers are missing.
# ALLOW_UNKNOWN_CLIENT_IP=true

# =============================================================================
# CLI / Test Harness / Diagnostics
# =============================================================================
CLI_HEADERS_TIMEOUT_MS=0
CLI_BODY_TIMEOUT_MS=0
CLI_FINALIZE_TIMEOUT_MS=600000

# CLI / verifier harness overrides.
# STARK_BALLOT_CLI_BASE_URL=http://127.0.0.1:3000
# CLI_VERIFIER_TMP_DIR=/tmp
# STARK_BALLOT_WASM_MODULE_PATH=public/wasm/risc0_wasm_wrapper.js
# STARK_BALLOT_WASM_BASE_URL=http://127.0.0.1:3000

# Experimental Hono API surface.
# HONO_API_ENABLED=true
# HONO_API_MODE=readonly

# Logging
# LOG_LEVEL=debug
# LOG_FORMAT=text
# LOG_SERVICE=app
# APP_ENV=development
# NEXT_PUBLIC_APP_ENV=development
# LOG_INCLUDE_STACK=true
# LOG_IP_HASH_SALT=replace-me

# Debug helpers
# DEBUG_FILE_STORE=1
# DEBUG_FINALIZE=1
# DISABLE_STRICT_CSP=1

# =============================================================================
# Terraform local backend/tfvars generation (optional)
# =============================================================================
# These values are only used by scripts/terraform/render-*.sh to generate
# git-ignored terraform/*.local.* files. Keep concrete values in .env.local or
# your shell environment, not in tracked Terraform files.
#
# TERRAFORM_AWS_ACCOUNT_ID=<12-digit-account-id>
# TERRAFORM_AWS_REGION=ap-northeast-1
# TERRAFORM_STATE_BUCKET=<terraform-state-bucket-name>
# TERRAFORM_ECR_SIGNING_PROFILE_NAME=<signing-profile-name>
# TERRAFORM_CODESTAR_CONNECTION_ID=<connection-id>
# TERRAFORM_CODEBUILD_SOURCE_LOCATION=https://github.com/hwatanabe-jp/<repo-name>.git
#
# Option A: provide the full digest-pinned prover image URI.
# TERRAFORM_ECS_IMAGE_URI_DEVELOP=<account-id>.dkr.ecr.ap-northeast-1.amazonaws.com/stark-ballot-simulator/zkvm-prover-develop@sha256:<64-hex-digest>
# TERRAFORM_ECS_IMAGE_URI_MAIN=<account-id>.dkr.ecr.ap-northeast-1.amazonaws.com/stark-ballot-simulator/zkvm-prover-main@sha256:<64-hex-digest>
#
# Option B: provide only the image digest and let the helper construct the URI.
# TERRAFORM_ZKVM_PROVER_DIGEST_DEVELOP=sha256:<64-hex-digest>
# TERRAFORM_ZKVM_PROVER_DIGEST_MAIN=sha256:<64-hex-digest>
#
# Callback Lambda can be provided as a full ARN or function name.
# TERRAFORM_FINALIZE_CALLBACK_LAMBDA_ARN_DEVELOP=arn:aws:lambda:ap-northeast-1:<account-id>:function:<develop-finalize-callback-function>
# TERRAFORM_FINALIZE_CALLBACK_LAMBDA_ARN_MAIN=arn:aws:lambda:ap-northeast-1:<account-id>:function:<main-finalize-callback-function>
# TERRAFORM_FINALIZE_CALLBACK_FUNCTION_NAME_DEVELOP=<develop-finalize-callback-function>
# TERRAFORM_FINALIZE_CALLBACK_FUNCTION_NAME_MAIN=<main-finalize-callback-function>
#
# Comma-separated S3 CORS origins. Required for tfvars generation so deploys do
# not silently remove browser access to proof bundle downloads.
# TERRAFORM_S3_CORS_ALLOWED_ORIGINS_DEVELOP=https://develop.<amplify-app-id>.amplifyapp.com
# TERRAFORM_S3_CORS_ALLOWED_ORIGINS_MAIN=https://main.<amplify-app-id>.amplifyapp.com,https://<public-domain>
