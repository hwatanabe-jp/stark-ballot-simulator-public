{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StateBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::<TERRAFORM_STATE_BUCKET>"
    },
    {
      "Sid": "StateObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::<TERRAFORM_STATE_BUCKET>/*"
    },
    {
      "Sid": "InfraServicesEC2",
      "Effect": "Allow",
      "Action": ["ec2:*"],
      "Resource": "*"
    },
    {
      "Sid": "InfraServicesECS",
      "Effect": "Allow",
      "Action": ["ecs:*"],
      "Resource": "*"
    },
    {
      "Sid": "InfraServicesECR",
      "Effect": "Allow",
      "Action": ["ecr:*"],
      "Resource": "*"
    },
    {
      "Sid": "InfraServicesSQS",
      "Effect": "Allow",
      "Action": ["sqs:*"],
      "Resource": "*"
    },
    {
      "Sid": "InfraServicesStepFunctions",
      "Effect": "Allow",
      "Action": ["states:*"],
      "Resource": "*"
    },
    {
      "Sid": "InfraServicesLogs",
      "Effect": "Allow",
      "Action": ["logs:*"],
      "Resource": "*"
    },
    {
      "Sid": "InfraServicesS3",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
        "arn:aws:s3:::stark-ballot-simulator-proof-bundles-*",
        "arn:aws:s3:::stark-ballot-simulator-proof-bundles-*/*",
        "arn:aws:s3:::stark-ballot-simulator-cloudtrail-*",
        "arn:aws:s3:::stark-ballot-simulator-cloudtrail-*/*"
      ]
    },
    {
      "Sid": "InfraServicesCodeBuild",
      "Effect": "Allow",
      "Action": ["codebuild:*"],
      "Resource": "arn:aws:codebuild:ap-northeast-1:<AWS_ACCOUNT_ID>:project/stark-ballot-simulator-*"
    },
    {
      "Sid": "InfraServicesLambda",
      "Effect": "Allow",
      "Action": ["lambda:*"],
      "Resource": "arn:aws:lambda:ap-northeast-1:<AWS_ACCOUNT_ID>:function:stark-ballot-simulator-*"
    },
    {
      "Sid": "InfraServicesCloudTrail",
      "Effect": "Allow",
      "Action": ["cloudtrail:*"],
      "Resource": "*"
    },
    {
      "Sid": "IAMScoped",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PassRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:ListRolePolicies",
        "iam:TagRole",
        "iam:UntagRole"
      ],
      "Resource": [
        "arn:aws:iam::<AWS_ACCOUNT_ID>:role/stark-ballot-simulator-*",
        "arn:aws:iam::<AWS_ACCOUNT_ID>:policy/stark-ballot-simulator-*"
      ]
    }
  ]
}
