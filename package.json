{
  "name": "stark-ballot-simulator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_USE_MOCK_API=true NEXT_PUBLIC_TURNSTILE_BYPASS=1 TURNSTILE_BYPASS=1 RUNTIME_DEPLOYMENT_ENV=develop DISABLE_STRICT_CSP=1 USE_MOCK_STORE=true USE_MOCK_ZKVM=true next dev",
    "build": "pnpm run build:zkvm && pnpm run build:verifier-service && next build",
    "build:ci": "next build",
    "docs:book:build": "mdbook build public-book && ./scripts/docs/create-mdbook-readme-aliases.sh && ./scripts/docs/harden-mdbook-output.sh && ./scripts/docs/check-mdbook-security-tags.sh",
    "docs:book:serve": "mdbook serve public-book",
    "docs:book:mermaid:install": "mdbook-mermaid install public-book",
    "licenses:regen": "./scripts/docs/regenerate-license-metadata.sh",
    "start": "next start",
    "lint": "eslint .",
    "public-safety:scan": "./scripts/security/scan-public-safety.sh --all",
    "public-safety:scan:staged": "./scripts/security/scan-public-safety.sh --staged",
    "terraform:backend": "./scripts/terraform/render-backend-config.sh",
    "terraform:build-lambdas": "pnpm terraform:build-lambda:check-image-signature",
    "terraform:build-lambda:check-image-signature": "node scripts/build/build-check-image-signature-lambda.mjs",
    "terraform:iam-docs": "./scripts/terraform/render-admin-iam-docs.sh",
    "terraform:tfvars:develop": "./scripts/terraform/render-local-tfvars.sh develop",
    "terraform:tfvars:main": "./scripts/terraform/render-local-tfvars.sh main",
    "terraform:plan:develop": "./scripts/terraform/terraform-guarded.sh develop plan -var-file=develop.local.tfvars",
    "terraform:apply:develop": "./scripts/terraform/terraform-guarded.sh develop apply -var-file=develop.local.tfvars",
    "terraform:plan:main": "./scripts/terraform/terraform-guarded.sh main plan -var-file=main.local.tfvars",
    "terraform:apply:main": "./scripts/terraform/terraform-guarded.sh main apply -var-file=main.local.tfvars",
    "ci:verify": "pnpm format:check && pnpm lint && pnpm type-check && pnpm test:run && pnpm test:e2e:axe && pnpm test:e2e:mock",
    "formal:build": "cd formal && lake check-build && lake build",
    "formal:report": "cd formal && lake exe emitFormalReport",
    "formal:report:check": "cd formal && lake exe emitFormalReport --check",
    "formal:audit": "pnpm tsx scripts/formal/audit-formal.ts",
    "formal:audit:check": "pnpm tsx scripts/formal/audit-formal.ts --check",
    "formal:test:ts": "vitest run src/lib/verification/__tests__/formal-summary-vectors.test.ts src/lib/verification/__tests__/formal-check-definitions.test.ts 'src/app/(routes)/verify/lib/overall-status.test.ts' src/lib/zkvm/__tests__/formal-input-commitment-vectors.test.ts src/lib/zkvm/__tests__/formal-bitmap-vectors.test.ts src/lib/merkle/__tests__/formal-bitmap-merkle-vectors.test.ts scripts/__tests__/formal-report.test.ts",
    "formal:verify": "pnpm formal:build && pnpm formal:report:check && pnpm formal:vectors:check && pnpm formal:audit:check && pnpm formal:test:ts && prettier --check \"docs/current/formal/formal-report.json\" \"docs/current/formal/formal-audit.json\" \"docs/current/formal/generated-vectors/*.json\"",
    "formal:vectors": "cd formal && lake exe emitTestVectors && cd .. && prettier --write \"docs/current/formal/generated-vectors/*.json\"",
    "formal:vectors:check": "pnpm tsx scripts/formal/check-formal-vectors.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "next typegen && tsc --noEmit",
    "type-check:tsc": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:public": "vitest run --dir src && vitest run --dir scripts/security",
    "test:bench": "pnpm tsx scripts/tests/performance-benchmark.ts",
    "test:entrypoint-bundle": "bash scripts/tests/entrypoint-bundle.test.sh",
    "test:stark-tamper": "cd verifier-service && make test-tamper",
    "test:vitest:e2e": "vitest run **/*e2e*.test.ts",
    "test:cli": "pnpm tsx scripts/tests/cli-e2e-voting-flow.ts",
    "test:cli:mock": "USE_MOCK_STORE=true USE_MOCK_ZKVM=true RISC0_DEV_MODE=1 RUNTIME_DEPLOYMENT_ENV=develop pnpm tsx scripts/tests/cli-e2e-voting-flow.ts -- --user-choice A --scenario S0",
    "test:cli:real-prod:s0": "USE_MOCK_STORE=true USE_MOCK_ZKVM=false pnpm tsx scripts/tests/cli-e2e-voting-flow.ts -- --user-choice A --real-zkvm --zkvm-mode prod --scenario S0",
    "test:cli:real-prod:all": "USE_MOCK_STORE=true USE_MOCK_ZKVM=false pnpm tsx scripts/tests/cli-e2e-voting-flow.ts -- --user-choice A --real-zkvm --zkvm-mode prod --all-scenarios",
    "test:cli:real-dev": "USE_MOCK_STORE=true USE_MOCK_ZKVM=false RISC0_DEV_MODE=1 pnpm tsx scripts/tests/cli-e2e-voting-flow.ts -- --user-choice A --real-zkvm --zkvm-mode dev --scenario S0",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:mock": "NEXT_PUBLIC_TURNSTILE_BYPASS=1 TURNSTILE_BYPASS=1 RUNTIME_DEPLOYMENT_ENV=develop DISABLE_STRICT_CSP=1 USE_MOCK_ZKVM=true USE_MOCK_STORE=true playwright test --grep-invert @axe",
    "test:e2e:axe": "NEXT_PUBLIC_TURNSTILE_BYPASS=1 TURNSTILE_BYPASS=1 RUNTIME_DEPLOYMENT_ENV=develop DISABLE_STRICT_CSP=1 USE_MOCK_ZKVM=true USE_MOCK_STORE=true playwright test --grep @axe",
    "test:e2e:report": "playwright show-report",
    "clean": "rm -rf .next tsconfig.tsbuildinfo node_modules/.cache",
    "clean:next": "rm -rf .next",
    "clean:ts": "rm -f tsconfig.tsbuildinfo",
    "clean:cache": "pnpm store prune && rm -rf ~/.local/share/pnpm/store ~/.cache/pnpm && npm cache clean --force 2>/dev/null || true",
    "clean:all": "./scripts/build/clean-all.sh",
    "dev:clean": "pnpm clean && pnpm dev",
    "build:zkvm": "cd zkvm && cargo build --release",
    "build:clean": "pnpm clean && pnpm build",
    "build:verifier-service": "cargo build --release --manifest-path verifier-service/Cargo.toml"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "dependencies": {
    "@aws-crypto/sha256-js": "5.2.0",
    "@aws-sdk/client-dynamodb": "3.1052.0",
    "@aws-sdk/client-ecr": "3.1052.0",
    "@aws-sdk/client-lambda": "3.1052.0",
    "@aws-sdk/client-s3": "3.1052.0",
    "@aws-sdk/client-sfn": "3.1052.0",
    "@aws-sdk/client-sqs": "3.1052.0",
    "@aws-sdk/credential-providers": "3.1052.0",
    "@aws-sdk/lib-dynamodb": "3.1052.0",
    "@aws-sdk/s3-request-presigner": "3.1052.0",
    "@marsidev/react-turnstile": "1.5.2",
    "@noble/hashes": "2.2.0",
    "@smithy/protocol-http": "5.4.4",
    "@smithy/signature-v4": "5.4.4",
    "hono": "4.12.21",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "yauzl": "3.3.1",
    "yazl": "3.3.1",
    "zod": "3.25.17"
  },
  "devDependencies": {
    "@aws-amplify/backend": "1.22.0",
    "@aws-amplify/backend-cli": "1.8.2",
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "2.10.3",
    "@types/yazl": "3.3.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "10.5.0",
    "aws-cdk-lib": "2.257.0",
    "constructs": "10.6.0",
    "dotenv": "17.4.2",
    "esbuild": "0.28.0",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "fast-check": "4.8.0",
    "fs-extra": "11.3.5",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "undici": "8.3.0",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
